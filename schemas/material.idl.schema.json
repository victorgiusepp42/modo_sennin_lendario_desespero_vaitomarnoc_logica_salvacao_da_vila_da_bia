{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://local/modo_sennin_lendario_desespero_vaitomarnoc_logica_salvacao_da_vila_da_bia/material.idl.schema.json",
  "title": "Material Didático IDL",
  "type": "object",
  "required": ["meta", "structure"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "meta": {
      "type": "object",
      "required": ["id", "title", "version", "language"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$" },
        "title": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+(-[\\w.]+)?$" },
        "language": { "type": "string", "minLength": 2 },
        "description": { "type": "string" }
      }
    },
    "structure": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/section" }
    }
  },
  "$defs": {
    "section": {
      "type": "object",
      "required": ["id", "title", "blocks"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$" },
        "title": { "type": "string", "minLength": 1 },
        "blocks": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/block" }
        }
      }
    },
    "block": {
      "oneOf": [
        { "$ref": "#/$defs/hero" },
        { "$ref": "#/$defs/heading" },
        { "$ref": "#/$defs/paragraph" },
        { "$ref": "#/$defs/list" },
        { "$ref": "#/$defs/callout" },
        { "$ref": "#/$defs/image" },
        { "$ref": "#/$defs/code" },
        { "$ref": "#/$defs/divider" }
      ]
    },
    "hero": {
      "type": "object",
      "required": ["type", "title"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "hero" },
        "mascot": { "type": "boolean", "default": true },
        "eyebrow": { "type": "string" },
        "title": { "type": "string", "minLength": 1 },
        "subtitle": { "type": "string" }
      }
    },
    "heading": {
      "type": "object",
      "required": ["type", "level", "text"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "heading" },
        "level": { "type": "integer", "minimum": 1, "maximum": 6 },
        "text": { "type": "string", "minLength": 1 }
      }
    },
    "paragraph": {
      "type": "object",
      "required": ["type", "text"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "paragraph" },
        "text": { "type": "string", "minLength": 1 }
      }
    },
    "list": {
      "type": "object",
      "required": ["type", "items"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "list" },
        "ordered": { "type": "boolean", "default": false },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "callout": {
      "type": "object",
      "required": ["type", "variant", "text"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "callout" },
        "variant": { "enum": ["info", "warning", "tip"] },
        "title": { "type": "string" },
        "text": { "type": "string", "minLength": 1 }
      }
    },
    "image": {
      "type": "object",
      "required": ["type", "src", "alt"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "image" },
        "src": { "type": "string", "minLength": 1 },
        "alt": { "type": "string", "minLength": 1 },
        "caption": { "type": "string" }
      }
    },
    "code": {
      "type": "object",
      "required": ["type", "text"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "code" },
        "language": { "type": "string" },
        "text": { "type": "string" }
      }
    },
    "divider": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "divider" }
      }
    }
  }
}
